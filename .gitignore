# =============================================================================
# Vision Transformer Knowledge Distillation - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python Cache & Build Files
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Build artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Dataset Storage (Crucial: NYUv2 is ~2.8GB, Oxford Pets is large)
# -----------------------------------------------------------------------------
data/

# Large raw dataset format (never commit this)
*.mat

# -----------------------------------------------------------------------------
# Model Checkpoints (23MB+ each)
# -----------------------------------------------------------------------------
checkpoints/
*.pt
*.pth
*.ckpt

# -----------------------------------------------------------------------------
# Experiment Outputs & Logs
# -----------------------------------------------------------------------------
outputs/
logs/

# -----------------------------------------------------------------------------
# IDE / Editor Files
# -----------------------------------------------------------------------------
.vscode/
.idea/

# -----------------------------------------------------------------------------
# OS Metadata
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.swp
*~
tmp/
